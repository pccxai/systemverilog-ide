  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8b95a7"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier",
        "constant.language"
      ],
      "settings": {
        "foreground": "#a78bfa"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class",
        "variable.language.this"
      ],
      "settings": {
        "foreground": "#2dd4bf"
      }
    },
    {
      "name": "Identifiers",
      "scope": [
        "entity.name.function",
        "entity.name.module",
        "entity.name.tag",
        "variable.other.readwrite",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#60a5fa"
      }
    },
    {
      "name": "Literals",
      "scope": [
        "constant.numeric",
        "constant.other",
        "string",
        "string.quoted"
      ],
      "settings": {
        "foreground": "#fbbf24"
      }
    },
    {
      "name": "Diagnostics And Invalid",
      "scope": [
        "invalid",
        "invalid.illegal",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#f87171"
      }
    },
    {
      "name": "Source Default",
      "scope": [
        "source",
        "punctuation",
        "meta"
      ],
      "settings": {
        "foreground": "#e5e7eb"
      }
    }
  ]
}
